# Supabase runtime configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: override if product images are in a different bucket.
VITE_SUPABASE_PRODUCTS_BUCKET=products

# Optional: WhatsApp checkout destination number (digits only after normalization).
VITE_WHATSAPP_ORDER_NUMBER=27715231720

# Optional: enable static fallback catalog only for demos.
VITE_USE_FALLBACK_CATALOG=false
