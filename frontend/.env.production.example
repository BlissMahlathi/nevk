# Production frontend runtime config
# If the frontend is hosted separately from the backend, point this to the
# deployed backend API base URL.
# If both are served from the same domain behind a reverse proxy, you can omit
# this variable and the frontend will use /api by default.
VITE_API_BASE_URL=https://api.nevkcosmetics.com/api

# Optional: enable static fallback catalog only for demos.
# Keep false in real production so API issues are visible.
VITE_USE_FALLBACK_CATALOG=false
