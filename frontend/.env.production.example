# Production frontend runtime config
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
# Optional alternative key variable name used by some Supabase dashboards:
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-public-anon-key

# Optional: bucket that stores product images.
VITE_SUPABASE_PRODUCTS_BUCKET=products

# Optional: checkout target number for wa.me links.
VITE_WHATSAPP_ORDER_NUMBER=27715231720

# Optional: enable static fallback catalog only for demos.
# Keep false in real production so API issues are visible.
VITE_USE_FALLBACK_CATALOG=false
