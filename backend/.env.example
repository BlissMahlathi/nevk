DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=api.nevkcosmetics.com

# Frontend origins allowed to call the API.
# Netlify production is locked in here; add local origins only when needed.
CORS_ALLOWED_ORIGINS=https://nevk.netlify.app
CSRF_TRUSTED_ORIGINS=https://nevk.netlify.app

# PostgreSQL (recommended in production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nevk
DB_USER=nevk_user
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=300
WHITENOISE_MAX_AGE=31536000

# Background removal automation service (expects image file upload and binary image response)
BG_REMOVAL_SERVICE_URL=https://your-bg-service.example.com/remove
BG_REMOVAL_SERVICE_TOKEN=replace-with-service-token
BG_REMOVAL_TIMEOUT=25

# Security hardening
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY

# WhatsApp business number in international format, digits only.
# Example for South Africa: 27731234567
WHATSAPP_ORDER_NUMBER=27715231720