DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Frontend origins allowed to call the API.
# Include both production and local dev URLs as needed.
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8080
CSRF_TRUSTED_ORIGINS=https://your-domain.com,http://localhost:8080

# PostgreSQL (recommended in production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nevk
DB_USER=nevk_user
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=300

# Security hardening
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY

# WhatsApp business number in international format, digits only.
# Example for South Africa: 27731234567
WHATSAPP_ORDER_NUMBER=27715231720