DEBUG=True
SECRET_KEY=dev-only-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional admin hardening
ADMIN_URL=secure-admin/
ADMIN_ALLOWED_IPS=
ADMIN_ALLOWED_HOSTS=

# Local frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# SQLite is used by default in local development.
# Uncomment and update these values if you want local Postgres instead.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=nevk
# DB_USER=nevk_user
# DB_PASSWORD=replace-with-strong-password
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_CONN_MAX_AGE=300

# Optional background removal automation service
BG_REMOVAL_SERVICE_URL=
BG_REMOVAL_SERVICE_TOKEN=
BG_REMOVAL_TIMEOUT=25

# Local-only relaxed security defaults
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY

# WhatsApp business number in international format, digits only.
WHATSAPP_ORDER_NUMBER=27700000000
