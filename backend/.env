# Allow local frontend and Netlify preview during development.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://nevk.netlify.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://nevk.netlify.app

# Local DB: SQLite (no PostgreSQL credentials required for runserver).
