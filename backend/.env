# Nevk Cosmetics – Local development environment variables
# Use .env.example values for production deployment.

DEBUG=True
SECRET_KEY=django-insecure-nevk-local-dev-key

ALLOWED_HOSTS=localhost,127.0.0.1

# Admin hardening (local defaults)
ADMIN_URL=admin/
ADMIN_ALLOWED_IPS=
